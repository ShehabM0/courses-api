<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body style="margin: 0; padding: 40px 20px; background-color: #FAF9F5; font-family: monospace; font-size: 12px;">
  
  <div style="max-width: 600px; margin: 0 auto; background-color: white; padding: 20px; border-radius: 20px;">
    
    <h2 style="font-style: italic; color: black; text-align: center; margin: 0 0 20px;">EduCore</h2>
    
    <div style="padding: 25px;">
      <p style="margin: 0 0 20px; line-height: 1.5;">
        You're nearly there, use the following code to verify your email.
      </p>
      
      <div style="margin: 20px 0 25px 0; text-align: center;">
        <div
           style="display: inline-block;
                  background-color: #FAF9F5;
                  color: black;
                  font-weight: bold;
                  border-radius: 10px;
                  padding: 20px 40px;
                  text-decoration: none;
                  font-family: monospace;">
          {{code}}
        </div>
        <p style="margin-top: 20px; font-size: 12px; color: #999999; text-align: center;">
          If the code does not work, request another one.
        </p>
      </div>
      
      <div style="border-top: 1px solid #E5E5E0; text-align: center; font-size: 10px; color: #666;">
        <p style="color: #999999;">
          If you didn't request this email, you can safely ignore it.
        </p>
        <p style="color: #999999;">
          © 2026 EduCore. All rights reserved.
        </p>
      </div>
    </div>
    
    
  </div>
    
</body>

</html>
